{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus Agent",
  "version": "0.1.0",
  "identifier": "dev.nexus.agent",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build -w frontend"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: blob: http://127.0.0.1:8910 http://localhost:8910; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:8910 http://localhost:8910; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/nexus-agent-runtime"],
    "resources": {
      "../../frontend/dist": "dist"
    },
    "category": "DeveloperTool",
    "shortDescription": "GUI-native AI coding agent",
    "longDescription": "Nexus Agent is a GUI-native AI coding agent: a local hexagonal runtime plus a rich React frontend, driven by generic OpenAI/Anthropic-compatible APIs.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nexus"]
      }
    }
  }
}
